function Radar({ piliers, sel, onSel }) {
const W=300, H=300, CX=150, CY=150, R=92, n=piliers.length;
const ang = i => (2*Math.PI*i/n) - Math.PI/2;
const pt  = (i, sc) => { const a=ang(i), e=R*(sc/100); return { x:CX+e*Math.cos(a), y:CY+e*Math.sin(a) }; };
const lp  = i => { const a=ang(i), lR=R+28; return { x:CX+lR*Math.cos(a), y:CY+lR*Math.sin(a), a }; };
const anch= a => { const d=((a*180/Math.PI)+450)%360; if(d<22||d>338)return”middle”; if(d<158)return”start”; if(d<202)return”middle”; return”end”; };
const poly = piliers.map((p,i)=>{ const {x,y}=pt(i,p.score); return `${x},${y}`; }).join(” “);
const sc = v => v>=60?C.green:v>=40?C.gold:C.red;
return (
<svg width=“100%” viewBox=“0 0 300 300” style={{overflow:“visible”}}>
{[25,50,75,100].map(lv => {
const pts = piliers.map((*,i)=>{ const {x,y}=pt(i,lv); return `${x},${y}`; }).join(” “);
return <polygon key={lv} points={pts} fill=“none” stroke={C.border} strokeWidth={lv===100?1.2:0.5} opacity={0.7}/>;
})}
{piliers.map((*,i)=>{ const {x,y}=pt(i,100); return <line key={i} x1={CX} y1={CY} x2={x} y2={y} stroke={C.border} strokeWidth={0.7}/>; })}
<polygon points={poly} fill="#C9A84C14" stroke="#C9A84C" strokeWidth={1.5}/>
{piliers.map((p,i)=>{ const {x,y}=pt(i,p.score); const s=p.id===sel;
return <circle key={i} cx={x} cy={y} r={s?5.5:3.5} fill={s?C.gold:`${C.gold}BB`}
stroke={C.bg} strokeWidth={1.5} style={{cursor:“pointer”}} onClick={()=>onSel(p.id)}/>;
})}
{piliers.map((p,i)=>{ const {x,y,a}=lp(i); const s=p.id===sel;
return (<g key={i} style={{cursor:“pointer”}} onClick={()=>onSel(p.id)}>
{p.lines.map((l,li)=>(
<text key={li} x={x} y={y+li*11-(p.lines.length-1)*5.5}
textAnchor={anch(a)} fontSize={7.5}
fill={s?C.gold:C.muted} fontFamily=“sans-serif” fontWeight={s?“700”:“400”}>{l}</text>
))}
</g>);
})}
<text x={CX} y={CY+5} textAnchor="middle" fontSize={7} fill={C.dim}>Eden 360°</text>
</svg>
);
}

